# ============================================================
# DLNT v2 — 環境変数テンプレート
# cp .env.v2.example .env.v2 して値を設定
# docker compose -f docker-compose.v2.yaml --env-file .env.v2 up -d
# ============================================================

# --- PostgreSQL ---
DB_PASSWORD=changeme_strong_password

# --- Ollama (ホスト側で動作) ---
OLLAMA_MODEL=gpt-oss:20b

# --- SearXNG ---
SEARXNG_SECRET_KEY=change-me-to-a-random-string-32chars

# --- Whisper ---
# small: 軽量 / medium: バランス / large-v3: 高精度
WHISPER_MODEL=small

# --- ドキュメントディレクトリ (RAG対象) ---
# ~/dlnt-docs/ を作成してドキュメントを置く
DLNT_DOCS_DIR=~/dlnt-docs

# --- ログレベル ---
LOG_LEVEL=info

# ============================================================
# ローカルAIエージェント 環境変数設定
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env
# ============================================================

# ============================================================
# MyAI Local - 統合環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env
# ============================================================

# --- Dify Core ---
SECRET_KEY=your-secret-key-here
INIT_PASSWORD=LocalAI2026!
DEPLOY_ENV=PRODUCTION

# --- PostgreSQL ---
DB_USERNAME=dify
DB_PASSWORD=your-db-password
DB_DATABASE=dify

# --- Redis ---
REDIS_PASSWORD=your-redis-password

# --- Qdrant (Vector Store) ---
QDRANT_API_KEY=your-qdrant-api-key

# --- Ollama (ホスト側で動作) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gpt-oss:20b

# --- Open WebUI ---
WEBUI_NAME=MyAI

# --- Dify Sandbox ---
SANDBOX_API_KEY=dify-sandbox

# --- Plugin Daemon ---
PLUGIN_DAEMON_KEY=your-plugin-daemon-key
PLUGIN_INNER_API_KEY=your-plugin-inner-api-key

# --- Dify 公開URL (ポート8888で公開) ---
CONSOLE_API_URL=http://localhost:8888
CONSOLE_WEB_URL=http://localhost:8888
SERVICE_API_URL=http://localhost:8888
APP_API_URL=http://localhost:8888
APP_WEB_URL=http://localhost:8888
FILES_URL=http://localhost:8888

# --- SearXNG ---
SEARXNG_SECRET_KEY=myai-searxng-local-secret-key-change-me

# --- Whisper ---
# small: 軽量・高速 / medium: バランス / large-v3: 最高精度
WHISPER_MODEL=small

# --- Dify エージェント APIキー ---
# http://localhost:8888 でアプリ作成 → API Access → APIキーを取得してここに貼り付け
DIFY_API_KEY_RESEARCH=
DIFY_API_KEY_TASK=
DIFY_API_KEY_MINUTES=

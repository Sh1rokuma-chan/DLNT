# ============================================================
# DLNT — 環境変数テンプレート
# cp .env.example .env して値を設定
# docker compose up -d
# ============================================================

# --- PostgreSQL ---
DB_PASSWORD=changeme_strong_password

# --- Ollama (ホスト側で動作) ---
OLLAMA_MODEL=gpt-oss:20b

# --- llama.cpp サーバー (qwen3.5 等 Ollama非対応モデル用) ---
# ./dlnt.sh up でランチャー起動。モデル選択時にオンデマンド自動起動。
LLAMA_CPP_URL=http://host.docker.internal:11435

# --- SearXNG ---
SEARXNG_SECRET_KEY=change-me-to-a-random-string-32chars

# --- Whisper ---
# small: 軽量 / medium: バランス / large-v3: 高精度
WHISPER_MODEL=small

# --- ドキュメントディレクトリ (RAG対象) ---
# ~/dlnt-docs/ を作成してドキュメントを置く
DLNT_DOCS_DIR=~/dlnt-docs

# --- ログレベル ---
LOG_LEVEL=info

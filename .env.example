# ============================================================
# MyAI Local — 環境変数テンプレート (v3)
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env
# ============================================================

# --- Ollama (ホスト側で動作) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gpt-oss:20b

# --- Open WebUI ---
WEBUI_NAME=MyAI

# --- SearXNG ---
SEARXNG_SECRET_KEY=change-me-to-a-random-string

# --- Whisper ---
# small: 軽量・高速 / medium: バランス / large-v3: 最高精度
WHISPER_MODEL=small
